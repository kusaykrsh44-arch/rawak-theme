<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="canonical" href="{{ canonical_url }}">
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <title>
    {{ page_title }}{% if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif %}
    {% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}
    {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% comment %} روابط بديلة للغات المتاحة (hreflang) لمحركات البحث {% endcomment %}
  {% for language in localization.available_languages %}
    <link rel="alternate" hreflang="{{ language.iso_code }}" href="{{ request.origin }}{{ language.root_url }}{{ canonical_url | remove: request.origin }}">
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ request.origin }}{{ canonical_url }}">

  {% comment %} Open Graph / Twitter {% endcomment %}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:type" content="{% if template contains 'product' %}product{% else %}website{% endif %}">
  <meta property="og:title" content="{{ page_title }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {% if page_description %}<meta property="og:description" content="{{ page_description | escape }}">{% endif %}
  {% if page_image %}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
    <meta name="twitter:card" content="summary_large_image">
  {% else %}
    <meta name="twitter:card" content="summary">
  {% endif %}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=El+Messiri:wght@500;600;700&family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <link rel="icon" href="{{ settings.favicon | image_url: width: 32 }}" type="image/png">

  {% if settings.accent_color != blank %}
    <style>
      :root{ --color-clay: {{ settings.accent_color }}; }
    </style>
  {% endif %}

  {% comment %} بيانات منظمة (Schema) للمتجر - تساعد بالظهور في نتائج البحث {% endcomment %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | append: page_url | json }},
    {% if settings.favicon %}"logo": {{ settings.favicon | image_url: width: 512 | prepend: "https:" | json }},{% endif %}
    "sameAs": [
      {% if settings.social_instagram != blank %}{{ settings.social_instagram | json }},{% endif %}
      {% if settings.social_tiktok != blank %}{{ settings.social_tiktok | json }}{% endif %}
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ request.origin }}{{ routes.search_url }}?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</head>
<body class="template-{{ request.page_type }}">

  {% section 'announcement-bar' %}
  {% section 'header' %}
  {% render 'cart-drawer' %}

  <main id="MainContent">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script>
    window.theme = window.theme || {};
    window.theme.strings = {
      adding: {{ 'products.product.adding' | t | json }},
      added: {{ 'products.product.added' | t | json }},
      addToCart: {{ 'products.product.add_to_cart' | t | json }},
      soldOut: {{ 'products.product.sold_out' | t | json }},
      unavailableOption: {{ 'products.product.unavailable_option' | t | json }},
      inStock: {{ 'products.product.in_stock' | t | json }},
      viewProduct: {{ 'products.product.view_product' | t | json }},
      addAllToCart: {{ 'products.product.add_all_to_cart' | t | json }},
      redirecting: {{ 'products.product.redirecting' | t | json }},
      errorGeneric: {{ 'products.product.error' | t | json }},
      cartEmptyDrawer: {{ 'cart.general.empty_drawer' | t | json }},
      cartContinue: {{ 'general.continue_shopping' | t | json }},
      cartRemove: {{ 'cart.general.remove' | t | json }},
      freeShippingReached: {{ 'cart.general.free_shipping_reached' | t | json }},
      freeShippingRemainingTemplate: {{ 'cart.general.free_shipping_remaining' | t: amount: '__AMOUNT__' | json }},
      genericError: {{ 'cart.general.empty' | t | json }}
    };
    window.theme.moneyFormat = {{ shop.money_format | json }};
    window.theme.routes = { cartAdd: '/cart/add.js', cartChange: '/cart/change.js', cart: '/cart.js' };
  </script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
