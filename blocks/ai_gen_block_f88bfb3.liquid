{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-magazine-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-magazine-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-magazine-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    color: {{ block.settings.category_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    margin-bottom: 12px;
    display: block;
  }

  .ai-magazine-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-magazine-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-featured-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-article-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
  }

  .ai-magazine-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-magazine-featured-{{ ai_gen_id }} .ai-magazine-image-wrapper-{{ ai_gen_id }} {
    aspect-ratio: 16 / 10;
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} .ai-magazine-image-wrapper-{{ ai_gen_id }} {
    aspect-ratio: 4 / 3;
  }

  .ai-magazine-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-magazine-article-{{ ai_gen_id }}:hover .ai-magazine-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-magazine-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-magazine-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-magazine-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-magazine-article-category-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.category_color }};
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
    margin-bottom: 8px;
    display: block;
  }

  .ai-magazine-article-title-{{ ai_gen_id }} {
    font-size: 24px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    line-height: 1.3;
    font-weight: 700;
  }

  .ai-magazine-featured-{{ ai_gen_id }} .ai-magazine-article-title-{{ ai_gen_id }} {
    font-size: 32px;
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} .ai-magazine-article-title-{{ ai_gen_id }} {
    font-size: 18px;
  }

  .ai-magazine-article-excerpt-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 16px;
  }

  .ai-magazine-article-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-author-{{ ai_gen_id }} {
    font-weight: 600;
  }

  .ai-magazine-date-{{ ai_gen_id }} {
    opacity: 0.8;
  }

  .ai-magazine-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-magazine-link-{{ ai_gen_id }}:hover .ai-magazine-article-title-{{ ai_gen_id }} {
    color: {{ block.settings.category_color }};
  }

  .ai-magazine-bottom-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-bottom-grid-{{ ai_gen_id }} .ai-magazine-image-wrapper-{{ ai_gen_id }} {
    aspect-ratio: 4 / 3;
  }

  .ai-magazine-bottom-grid-{{ ai_gen_id }} .ai-magazine-article-title-{{ ai_gen_id }} {
    font-size: 18px;
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-magazine-featured-{{ ai_gen_id }},
    .ai-magazine-sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-magazine-bottom-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-layout-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-magazine-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-magazine-featured-{{ ai_gen_id }} .ai-magazine-article-title-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-magazine-sidebar-{{ ai_gen_id }} .ai-magazine-article-title-{{ ai_gen_id }},
    .ai-magazine-bottom-grid-{{ ai_gen_id }} .ai-magazine-article-title-{{ ai_gen_id }} {
      font-size: 16px;
    }
  }
{% endstyle %}

<ai-magazine-editorial-{{ ai_gen_id }} class="ai-magazine-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-magazine-header-{{ ai_gen_id }}">
        {% if block.settings.category != blank %}
          <span class="ai-magazine-category-{{ ai_gen_id }}">{{ block.settings.category }}</span>
        {% endif %}
        {% if block.settings.title != blank %}
          <h2 class="ai-magazine-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-magazine-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-magazine-grid-{{ ai_gen_id }}">
      <div class="ai-magazine-featured-{{ ai_gen_id }}">
        <article class="ai-magazine-article-{{ ai_gen_id }}">
          <a href="{{ block.settings.featured_article.url }}" class="ai-magazine-link-{{ ai_gen_id }}">
            <div class="ai-magazine-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.featured_article.image %}
                <img
                  src="{{ block.settings.featured_article.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.featured_article.image.alt | escape }}"
                  loading="lazy"
                  width="1200"
                  height="750"
                  class="ai-magazine-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-magazine-image-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-magazine-content-{{ ai_gen_id }}">
              {% if block.settings.featured_article.tags.size > 0 %}
                <span class="ai-magazine-article-category-{{ ai_gen_id }}">{{ block.settings.featured_article.tags.first }}</span>
              {% endif %}
              <h3 class="ai-magazine-article-title-{{ ai_gen_id }}">
                {% if block.settings.featured_article.title != blank %}
                  {{ block.settings.featured_article.title }}
                {% else %}
                  Featured article title
                {% endif %}
              </h3>
              {% if block.settings.show_excerpt and block.settings.featured_article.excerpt != blank %}
                <div class="ai-magazine-article-excerpt-{{ ai_gen_id }}">
                  {{ block.settings.featured_article.excerpt | strip_html | truncate: 150 }}
                </div>
              {% endif %}
              {% if block.settings.show_meta %}
                <div class="ai-magazine-article-meta-{{ ai_gen_id }}">
                  {% if block.settings.featured_article.author != blank %}
                    <span class="ai-magazine-author-{{ ai_gen_id }}">{{ block.settings.featured_article.author }}</span>
                  {% endif %}
                  {% if block.settings.featured_article.published_at %}
                    <span class="ai-magazine-date-{{ ai_gen_id }}">{{ block.settings.featured_article.published_at | date: '%B %d, %Y' }}</span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </a>
        </article>
      </div>

      <div class="ai-magazine-sidebar-{{ ai_gen_id }}">
        {% for i in (1..2) %}
          {% liquid
            assign article_key = 'sidebar_article_' | append: i
            assign article = block.settings[article_key]
          %}
          <article class="ai-magazine-article-{{ ai_gen_id }}">
            <a href="{{ article.url }}" class="ai-magazine-link-{{ ai_gen_id }}">
              <div class="ai-magazine-image-wrapper-{{ ai_gen_id }}">
                {% if article.image %}
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    alt="{{ article.image.alt | escape }}"
                    loading="lazy"
                    width="600"
                    height="450"
                    class="ai-magazine-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-magazine-image-placeholder-{{ ai_gen_id }}">
                    {{ 'blog-apparel-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-magazine-content-{{ ai_gen_id }}">
                {% if article.tags.size > 0 %}
                  <span class="ai-magazine-article-category-{{ ai_gen_id }}">{{ article.tags.first }}</span>
                {% endif %}
                <h3 class="ai-magazine-article-title-{{ ai_gen_id }}">
                  {% if article.title != blank %}
                    {{ article.title }}
                  {% else %}
                    Article title {{ i }}
                  {% endif %}
                </h3>
                {% if block.settings.show_meta %}
                  <div class="ai-magazine-article-meta-{{ ai_gen_id }}">
                    {% if article.author != blank %}
                      <span class="ai-magazine-author-{{ ai_gen_id }}">{{ article.author }}</span>
                    {% endif %}
                    {% if article.published_at %}
                      <span class="ai-magazine-date-{{ ai_gen_id }}">{{ article.published_at | date: '%B %d, %Y' }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    </div>

    <div class="ai-magazine-bottom-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign article_key = 'bottom_article_' | append: i
          assign article = block.settings[article_key]
        %}
        <article class="ai-magazine-article-{{ ai_gen_id }}">
          <a href="{{ article.url }}" class="ai-magazine-link-{{ ai_gen_id }}">
            <div class="ai-magazine-image-wrapper-{{ ai_gen_id }}">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 600 }}"
                  alt="{{ article.image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="450"
                  class="ai-magazine-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-magazine-image-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-magazine-content-{{ ai_gen_id }}">
              {% if article.tags.size > 0 %}
                <span class="ai-magazine-article-category-{{ ai_gen_id }}">{{ article.tags.first }}</span>
              {% endif %}
              <h3 class="ai-magazine-article-title-{{ ai_gen_id }}">
                {% if article.title != blank %}
                  {{ article.title }}
                {% else %}
                  Article title {{ i }}
                {% endif %}
              </h3>
              {% if block.settings.show_meta %}
                <div class="ai-magazine-article-meta-{{ ai_gen_id }}">
                  {% if article.author != blank %}
                    <span class="ai-magazine-author-{{ ai_gen_id }}">{{ article.author }}</span>
                  {% endif %}
                  {% if article.published_at %}
                    <span class="ai-magazine-date-{{ ai_gen_id }}">{{ article.published_at | date: '%B %d, %Y' }}</span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</ai-magazine-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class AiMagazineEditorial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('ai-magazine-editorial-{{ ai_gen_id }}', AiMagazineEditorial{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Magazine editorial layout",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "category",
      "label": "Category"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Latest Stories"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover our curated collection of editorial content"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Featured article"
    },
    {
      "type": "article",
      "id": "featured_article",
      "label": "Featured article"
    },
    {
      "type": "header",
      "content": "Sidebar articles"
    },
    {
      "type": "article",
      "id": "sidebar_article_1",
      "label": "Sidebar article 1"
    },
    {
      "type": "article",
      "id": "sidebar_article_2",
      "label": "Sidebar article 2"
    },
    {
      "type": "header",
      "content": "Bottom articles"
    },
    {
      "type": "article",
      "id": "bottom_article_1",
      "label": "Bottom article 1"
    },
    {
      "type": "article",
      "id": "bottom_article_2",
      "label": "Bottom article 2"
    },
    {
      "type": "article",
      "id": "bottom_article_3",
      "label": "Bottom article 3"
    },
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "Show author and date",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "category_color",
      "label": "Category",
      "default": "#A65A2E"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta text",
      "default": "#999999"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "category_size",
      "label": "Category size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Header title size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Header spacing",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Magazine editorial layout"
    }
  ]
}
{% endschema %}
