<section class="hero">
  <div class="hero__media">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 1800 }}" alt="{{ section.settings.heading | escape }}" loading="eager">
    {% else %}
      <img src="{{ 'rawak-hero.jpg' | asset_url }}" alt="عشبة المتة الطبيعية" loading="eager">
    {% endif %}
  </div>

  <div class="hero__content" data-reveal>
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'RAWAK · متة طبيعية' }}</span>
    <h1>{{ section.settings.heading | default: 'خذ نفسك، وارتاح مع رواك' }}</h1>
    <p>{{ section.settings.text | default: 'عشبة متة طبيعية ١٠٠٪، بدون إضافات ولا معالجة كيميائية. قطفة حرفية بتدّيك رتوة الحقيقية في كل كوب.' }}</p>
    <div class="hero__actions">
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn-primary">{{ section.settings.button_label | default: 'تسوّق المتة' }}</a>
      <a href="{{ section.settings.secondary_link | default: '#story' }}" class="btn btn-ghost">{{ section.settings.secondary_label | default: 'تعرف على القصة' }}</a>
    </div>
  </div>

  <div class="steam">
    <svg viewBox="0 0 1440 60" width="100%" height="60" preserveAspectRatio="none">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="#FBF7EE"/>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "قسم البداية (Hero)",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "صورة الخلفية" },
    { "type": "text", "id": "eyebrow", "label": "نص علوي صغير" },
    { "type": "text", "id": "heading", "label": "العنوان الرئيسي" },
    { "type": "textarea", "id": "text", "label": "الوصف" },
    { "type": "text", "id": "button_label", "label": "نص الزر الأول" },
    { "type": "url", "id": "button_link", "label": "رابط الزر الأول" },
    { "type": "text", "id": "secondary_label", "label": "نص الزر الثاني" },
    { "type": "url", "id": "secondary_link", "label": "رابط الزر الثاني" }
  ],
  "presets": [{ "name": "قسم البداية (Hero)" }]
}
{% endschema %}
