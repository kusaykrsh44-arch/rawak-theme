<section class="page-main" style="max-width:640px;">
  <span class="eyebrow" style="justify-content:center;display:flex;">{{ section.settings.eyebrow | default: 'تواصل معنا' }}</span>
  <h1 style="text-align:center;">{{ page.title }}</h1>
  <div class="rte" style="text-align:center;margin-bottom:36px;">{{ page.content }}</div>

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <p style="background:var(--color-sage-light);color:var(--color-forest-dark);padding:16px 20px;border-radius:12px;font-weight:700;text-align:center;">
        {{ section.settings.success_message | default: 'تم استلام رسالتك، رح نرد عليك بأقرب وقت 🌿' }}
      </p>
    {% else %}
      {% if form.errors %}
        <p style="color:var(--color-clay);font-weight:700;margin-bottom:16px;">{{ form.errors | default_errors }}</p>
      {% endif %}
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div>
          <label style="display:block;font-weight:700;font-size:.9rem;margin-bottom:6px;" for="ContactFormName">الاسم</label>
          <input type="text" id="ContactFormName" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                 style="width:100%;padding:13px 16px;border-radius:12px;border:1px solid var(--color-line);">
        </div>
        <div>
          <label style="display:block;font-weight:700;font-size:.9rem;margin-bottom:6px;" for="ContactFormEmail">البريد الإلكتروني *</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" required
                 value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                 style="width:100%;padding:13px 16px;border-radius:12px;border:1px solid var(--color-line);">
        </div>
        <div>
          <label style="display:block;font-weight:700;font-size:.9rem;margin-bottom:6px;" for="ContactFormPhone">الهاتف (اختياري)</label>
          <input type="tel" id="ContactFormPhone" name="contact[phone]" value="{% if form.phone %}{{ form.phone }}{% endif %}"
                 style="width:100%;padding:13px 16px;border-radius:12px;border:1px solid var(--color-line);">
        </div>
        <div>
          <label style="display:block;font-weight:700;font-size:.9rem;margin-bottom:6px;" for="ContactFormMessage">رسالتك *</label>
          <textarea id="ContactFormMessage" name="contact[body]" rows="5" required
                    style="width:100%;padding:13px 16px;border-radius:12px;border:1px solid var(--color-line);resize:vertical;">{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="align-self:flex-start;">إرسال</button>
      </div>
    {% endif %}
  {% endform %}

  {% if section.settings.whatsapp != blank %}
    <div style="text-align:center;margin-top:36px;padding-top:28px;border-top:1px solid var(--color-line);">
      <p>أو تواصل معنا مباشرة عبر واتساب</p>
      <a href="{{ section.settings.whatsapp }}" class="btn btn-outline" target="_blank" rel="noopener">راسلنا على واتساب</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "صفحة تواصل معنا",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "نص علوي صغير" },
    { "type": "text", "id": "success_message", "label": "رسالة النجاح بعد الإرسال" },
    { "type": "url", "id": "whatsapp", "label": "رابط واتساب" }
  ]
}
{% endschema %}
