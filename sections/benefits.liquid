<section class="benefits">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'ليش رواك' }}</span>
      <h2>{{ section.settings.heading | default: 'راحة طبيعية، بلا استعجال' }}</h2>
      <p>{{ section.settings.text | default: 'كل كوب من رواك مصمم يخلّيك ترجع لهدوءك، بمكونات طبيعية بس.' }}</p>
    </div>

    <div class="benefits__grid">
      {% for block in section.blocks %}
        <div class="benefit-card" data-reveal {{ block.shopify_attributes }}>
          <div class="benefit-card__icon">
            {% case block.settings.icon %}
              {% when 'leaf' %}
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M10 38C10 20 20 10 38 10c0 18-10 28-28 28Z"/><path d="M12 36c8-8 16-16 24-24"/></svg>
              {% when 'cup' %}
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M10 16h22v14a11 11 0 0 1-22 0V16Z"/><path d="M32 20h4a5 5 0 0 1 0 10h-4"/><path d="M16 6c0 3-3 3-3 6M24 6c0 3-3 3-3 6"/></svg>
              {% when 'heart' %}
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M24 40S6 29 6 17a10 10 0 0 1 18-6 10 10 0 0 1 18 6c0 12-18 23-18 23Z"/></svg>
              {% else %}
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="24" cy="24" r="16"/><path d="M24 16v8l6 4"/></svg>
            {% endcase %}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "الفوائد",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "نص علوي صغير" },
    { "type": "text", "id": "heading", "label": "العنوان" },
    { "type": "textarea", "id": "text", "label": "الوصف" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "ميزة",
      "settings": [
        { "type": "select", "id": "icon", "label": "الأيقونة", "options": [
          { "value": "leaf", "label": "ورقة" },
          { "value": "cup", "label": "كوب" },
          { "value": "heart", "label": "قلب" },
          { "value": "clock", "label": "ساعة" }
        ], "default": "leaf" },
        { "type": "text", "id": "title", "label": "العنوان", "default": "طبيعية 100٪" },
        { "type": "textarea", "id": "text", "label": "الوصف", "default": "بدون مواد حافظة أو نكهات صناعية." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "benefit", "settings": { "icon": "leaf", "title": "طبيعية 100٪", "text": "أوراق متة مقطوفة يدويًا، بدون أي إضافات." } },
      { "type": "benefit", "settings": { "icon": "cup", "title": "نكهة أصيلة", "text": "تجفيف بطيء وطبيعي يحافظ على النكهة الحقيقية." } },
      { "type": "benefit", "settings": { "icon": "heart", "title": "طاقة هادئة", "text": "تنبيه طبيعي بدون التوتر اللي بيجيبه الكافيين." } }
    ]
  },
  "presets": [{ "name": "الفوائد" }]
}
{% endschema %}
