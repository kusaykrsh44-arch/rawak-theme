<section class="cart-main">
  <div class="container">
    <h1>{{ 'cart.general.title' | t }}</h1>

    {% if cart.item_count > 0 %}
      <div class="cart-layout">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item">
              <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">
              <div style="flex:1;">
                <div class="cart-item__title">{{ item.product.title }}</div>
                {% unless item.variant.title == 'Default Title' %}
                  <div style="font-size:.88rem;color:var(--color-ink-soft);">{{ item.variant.title }}</div>
                {% endunless %}
                <div style="font-size:.9rem;">{{ item.quantity }} × {{ item.price | money }}</div>
                <button class="cart-item__remove" data-cart-remove="{{ item.key }}">{{ 'cart.general.remove' | t }}</button>
              </div>
              <strong>{{ item.line_price | money }}</strong>
            </div>
          {% endfor %}
        </div>

        <div class="cart-summary">
          <div class="row"><span>{{ 'cart.general.subtotal' | t }}</span><span>{{ cart.total_price | money }}</span></div>
          <div class="row" style="color:var(--color-ink-soft);font-size:.85rem;">{{ 'cart.general.shipping_note' | t }}</div>
          <div class="row total"><span>{{ 'cart.general.total' | t }}</span><span>{{ cart.total_price | money }}</span></div>
          <a href="{{ routes.cart_url }}/checkout" class="btn btn-primary" style="width:100%;margin-top:18px;">{{ 'cart.general.checkout' | t }}</a>
        </div>
      </div>
    {% else %}
      <div class="cart-empty">
        <p>{{ 'cart.general.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">{{ 'cart.general.shop_now' | t }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{ "name": "صفحة السلة" }
{% endschema %}
