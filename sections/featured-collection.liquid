<section class="products">
  <div class="container">
    <div class="section-head">
      <div class="heading-block">
        <span class="eyebrow">{{ section.settings.eyebrow | default: 'المجموعة' }}</span>
        <h2>{{ section.settings.heading | default: 'منتجات رواك' }}</h2>
      </div>
      <p>{{ section.settings.text }}</p>
    </div>

    <div class="product-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% if collection != blank %}
        {% for product in collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <div class="product-card">
            <div class="product-card__media">
              <img src="{{ 'rawak-product-1.jpg' | asset_url }}" alt="متة رواك">
            </div>
            <div class="product-card__body">
              <h3>متة رواك الطبيعية</h3>
              <div class="product-card__price"><span>{{ 180 | times: 100 | money }}</span></div>
              <button class="product-card__cta" disabled>اربط مجموعة من المخصص</button>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="products__footer">
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn-outline">{{ section.settings.button_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "منتجات مميزة",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "نص علوي صغير" },
    { "type": "text", "id": "heading", "label": "العنوان" },
    { "type": "textarea", "id": "text", "label": "الوصف" },
    { "type": "collection", "id": "collection", "label": "المجموعة" },
    { "type": "range", "id": "products_to_show", "label": "عدد المنتجات", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "button_label", "label": "نص الزر", "default": "عرض كل المنتجات" },
    { "type": "url", "id": "button_link", "label": "رابط الزر" }
  ],
  "presets": [{ "name": "منتجات مميزة" }]
}
{% endschema %}
