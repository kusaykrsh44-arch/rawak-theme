<section class="reviews" id="reviews">
  <div class="container">
    <div class="reviews__head">
      <div>
        <span class="eyebrow">آراء العملاء</span>
        <h2>{{ section.settings.heading | default: 'شو بيحكوا عنا' }}</h2>
      </div>
      <div class="reviews__score">
        <span class="reviews__score-num">{{ section.settings.average_rating | default: '4.9' }}</span>
        <div>
          <span class="rating-stars">★★★★★</span>
          <div style="font-size:.85rem;color:var(--color-ink-soft);">{{ section.blocks.size }} تقييم موثّق</div>
        </div>
      </div>
    </div>

    <div class="reviews__grid">
      {% for block in section.blocks %}
        <div class="review-card" data-reveal {{ block.shopify_attributes }}>
          <span class="rating-stars">
            {% for i in (1..5) %}{% if i <= block.settings.stars %}★{% else %}☆{% endif %}{% endfor %}
          </span>
          <p>{{ block.settings.text }}</p>
          <div class="review-card__author">{{ block.settings.author }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "تقييمات العملاء",
  "settings": [
    { "type": "text", "id": "heading", "label": "العنوان" },
    { "type": "text", "id": "average_rating", "label": "متوسط التقييم" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "تقييم",
      "settings": [
        { "type": "range", "id": "stars", "label": "عدد النجوم", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "نص التقييم" },
        { "type": "text", "id": "author", "label": "الاسم" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "review", "settings": { "stars": 5, "text": "من أول رشفة حسيت بالفرق، نكهة طبيعية وهدوء حقيقي.", "author": "سارة" } },
      { "type": "review", "settings": { "stars": 5, "text": "التغليف حلو والشحن كان سريع، صارت من طقوس الصبح عندي.", "author": "عمر" } },
      { "type": "review", "settings": { "stars": 4, "text": "نكهة أصيلة فعلاً، حابب جرب باقي الأنواع كمان.", "author": "لينا" } }
    ]
  },
  "presets": [{ "name": "تقييمات العملاء" }]
}
{% endschema %}
