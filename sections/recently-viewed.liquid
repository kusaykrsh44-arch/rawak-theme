<section class="products dynamic-products" data-recently-viewed hidden>
  <div class="container">
    <div class="section-head">
      <div class="heading-block">
        <span class="eyebrow">شوهدت مؤخرًا</span>
        <h2>{{ section.settings.heading | default: 'رجعتلك هدول' }}</h2>
      </div>
    </div>
    <div class="product-grid" data-dynamic-grid></div>
  </div>
</section>

{% schema %}
{
  "name": "شوهدت مؤخرًا",
  "settings": [
    { "type": "text", "id": "heading", "label": "العنوان" }
  ],
  "presets": [{ "name": "شوهدت مؤخرًا" }]
}
{% endschema %}
