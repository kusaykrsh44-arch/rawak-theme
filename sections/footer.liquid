<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-logo">{{ section.settings.footer_title | default: shop.name | default: 'RAWAK' }}</div>
        <p>{{ section.settings.about_text | default: 'متة طبيعية 100٪، من غير أي إضافات، لكل لحظة رايقة بتستحقها.' }}</p>
        <div class="social-row">
          {% if section.settings.instagram != blank %}
            <a href="{{ section.settings.instagram }}" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok != blank %}
            <a href="{{ section.settings.tiktok }}" aria-label="TikTok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 4v10.2a3.8 3.8 0 1 1-3-3.7"/><path d="M14 4c.6 2.4 2.4 4 5 4.2"/></svg>
            </a>
          {% endif %}
          {% if section.settings.whatsapp != blank %}
            <a href="{{ section.settings.whatsapp }}" aria-label="WhatsApp">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 12a9 9 0 1 1-4.2-7.6L21 3l-1 4.3A9 9 0 0 1 21 12Z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <div>
        <h4>تسوّق</h4>
        <ul class="footer-links">
          {% for link in section.settings.shop_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div>
        <h4>الشركة</h4>
        <ul class="footer-links">
          {% for link in section.settings.company_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div>
        <h4>تواصل معنا</h4>
        <ul class="footer-links">
          {% if section.settings.email != blank %}<li>{{ section.settings.email }}</li>{% endif %}
          {% if section.settings.phone != blank %}<li>{{ section.settings.phone }}</li>{% endif %}
          {% if section.settings.address != blank %}<li>{{ section.settings.address }}</li>{% endif %}
        </ul>

        {% if localization.available_languages.size > 1 or localization.available_countries.size > 1 %}
          <div class="footer-localization">
            {% if localization.available_languages.size > 1 %}
              {% form 'localization', class: 'localization-form' %}
                <label for="footer-lang-select" style="font-size:.78rem;opacity:.7;display:block;margin-bottom:6px;">{{ 'localization.language_label' | t }}</label>
                <select name="locale_code" id="footer-lang-select" onchange="this.form.submit()">
                  {% for language in localization.available_languages %}
                    <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>{{ language.endonym_name | capitalize }}</option>
                  {% endfor %}
                </select>
              {% endform %}
            {% endif %}

            {% if localization.available_countries.size > 1 %}
              {% form 'localization', class: 'localization-form' %}
                <label for="footer-country-select" style="font-size:.78rem;opacity:.7;display:block;margin:14px 0 6px;">{{ 'localization.country_label' | t }}</label>
                <select name="country_code" id="footer-country-select" onchange="this.form.submit()">
                  {% for country in localization.available_countries %}
                    <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>{{ country.name }} ({{ country.currency.iso_code }})</option>
                  {% endfor %}
                </select>
              {% endform %}
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }} — {{ 'footer.rights' | t }}</span>
      <span class="payment-icons">{{ shop.enabled_payment_types | join: ' · ' }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "الفوتر",
  "settings": [
    { "type": "text", "id": "footer_title", "label": "اسم العلامة" },
    { "type": "textarea", "id": "about_text", "label": "نبذة قصيرة" },
    { "type": "link_list", "id": "shop_menu", "label": "قائمة تسوّق" },
    { "type": "link_list", "id": "company_menu", "label": "قائمة الشركة" },
    { "type": "text", "id": "email", "label": "البريد الإلكتروني" },
    { "type": "text", "id": "phone", "label": "الهاتف" },
    { "type": "text", "id": "address", "label": "العنوان" },
    { "type": "url", "id": "instagram", "label": "رابط انستغرام" },
    { "type": "url", "id": "tiktok", "label": "رابط تيك توك" },
    { "type": "url", "id": "whatsapp", "label": "رابط واتساب" }
  ]
}
{% endschema %}
