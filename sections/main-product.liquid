<section class="product-main" data-product-json="{{ product | json | escape }}">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">{{ shop.name }}</a>
      {% if product.collections.first %}
        <span>/</span><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      {% endif %}
      <span>/</span><span aria-current="page">{{ product.title }}</span>
    </nav>

    {% assign selected_variant = product.selected_or_first_available_variant %}
    {% assign selected_image = selected_variant.featured_image | default: product.featured_image %}

    <div class="product-layout">

      <div class="product-gallery">
        <div class="product-gallery__main" data-zoom-wrap>
          {% if selected_image %}
            <img src="{{ selected_image | image_url: width: 1000 }}"
                 alt="{{ selected_image.alt | escape }}" data-gallery-main>
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-gallery__thumbs">
            {% for image in product.images %}
              <img src="{{ image | image_url: width: 200 }}"
                   data-full-src="{{ image | image_url: width: 1000 }}"
                   data-gallery-thumb
                   data-variant-image-id="{{ image.id }}"
                   class="option-pill-thumb {% if image.id == selected_image.id %}active{% endif %}"
                   loading="lazy"
                   alt="{{ image.alt | escape }}">
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-info">
        <div class="product-info__top">
          <div>
            <span class="eyebrow">{{ product.type | default: 'متة طبيعية' }}</span>
            <h1>{{ product.title }}</h1>
          </div>
          <button class="wishlist-btn" data-wishlist-toggle data-product-id="{{ product.id }}" aria-label="أضف للمفضلة">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 20S3 14 3 8.5A4.5 4.5 0 0 1 12 6a4.5 4.5 0 0 1 9 2.5C21 14 12 20 12 20Z"/></svg>
          </button>
        </div>

        {% if section.settings.show_rating and section.settings.rating_count > 0 %}
          <a href="#reviews" class="rating-summary">
            <span class="rating-stars" aria-hidden="true">★★★★★</span>
            <span>{{ section.settings.rating_count }} تقييم</span>
          </a>
        {% endif %}

        <div class="product-price" data-product-price>
          {% if selected_variant.compare_at_price > selected_variant.price %}
            <s data-compare-price>{{ selected_variant.compare_at_price | money }}</s>
          {% endif %}
          <span data-final-price>{{ selected_variant.price | money }}</span>
        </div>

        <div class="product-desc rte">{{ product.description }}</div>

        {% form 'product', product, data-add-to-cart-form: true %}
          <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id>

          {% for option in product.options_with_values %}
            <div class="option-picker" data-option-index="{{ forloop.index0 }}">
              <span class="option-picker__label">{{ option.name }}</span>
              <div class="option-picker__values">
                {% for value in option.values %}
                  <button type="button"
                          class="option-pill {% if value == option.selected_value %}active{% endif %}"
                          data-option-value="{{ value | escape }}"
                          data-option-index="{{ forloop.parentloop.index0 }}">
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          <div class="qty-row">
            <div class="qty-selector" data-qty-selector>
              <button type="button" data-qty-minus aria-label="إنقاص">−</button>
              <input type="number" name="quantity" value="1" min="1" aria-label="الكمية">
              <button type="button" data-qty-plus aria-label="زيادة">+</button>
            </div>
            <span class="stock-msg" data-stock-msg>
              {% if selected_variant.available %}{{ 'products.product.in_stock' | t }}{% else %}{{ 'products.product.sold_out' | t }}{% endif %}
            </span>
          </div>

          <div class="product-form__buttons">
            <button type="submit" class="btn btn-primary" data-add-btn {% unless selected_variant.available %}disabled{% endunless %}>
              <span data-add-btn-text>{% if selected_variant.available %}{{ 'products.product.add_to_cart' | t }}{% else %}{{ 'products.product.sold_out' | t }}{% endif %}</span>
            </button>
            {% if section.settings.show_buy_now %}
              <button type="submit" name="buy_now" class="btn btn-outline" data-buy-now {% unless selected_variant.available %}disabled{% endunless %}>{{ 'products.product.buy_now' | t }}</button>
            {% endif %}
          </div>
        {% endform %}

        <p class="delivery-estimate">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="15" height="12" rx="2"/><path d="M16 10h3l3 3v5h-6"/><circle cx="5.5" cy="18.5" r="1.5"/><circle cx="17.5" cy="18.5" r="1.5"/></svg>
          {{ section.settings.delivery_estimate | default: 'التوصيل المتوقع خلال 2–5 أيام عمل' }}
        </p>

        <div class="trust-badges">
          {% for block in section.blocks %}
            {% if block.type == 'trust_badge' %}
              <div class="trust-badge" {{ block.shopify_attributes }}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 6L9 17l-5-5"/></svg>
                <span>{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="share-row">
          <span>شارك:</span>
          <button type="button" data-share aria-label="مشاركة">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 10.5l6.8-3.8M8.6 13.5l6.8 3.8"/></svg>
          </button>
        </div>

        <div class="accordion">
          <details class="accordion-item" open>
            <summary>طريقة التحضير</summary>
            <div class="accordion-body">{{ section.settings.brew_instructions | default: 'ضع 2-3 ملاعق من عشبة المتة في الكوب، أضف ماء ساخن (غير مغلي) بحرارة حوالي 80°، واتركها بضع دقائق قبل الشرب. يمكن إعادة التبخير عدة مرات.' }}</div>
          </details>
          <details class="accordion-item">
            <summary>الشحن والإرجاع</summary>
            <div class="accordion-body">{{ section.settings.shipping_info | default: 'شحن خلال 2-5 أيام عمل داخل كل المدن. إمكانية الإرجاع خلال 7 أيام إذا كان المنتج غير مفتوح.' }}</div>
          </details>
          {% for block in section.blocks %}
            {% if block.type == 'faq' %}
              <details class="accordion-item" {{ block.shopify_attributes }}>
                <summary>{{ block.settings.question }}</summary>
                <div class="accordion-body">{{ block.settings.answer }}</div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<div class="sticky-atc" data-sticky-atc>
  <div class="container sticky-atc__inner">
    <div class="sticky-atc__product">
      <img src="{{ product.featured_image | image_url: width: 100 }}" alt="">
      <span>{{ product.title }}</span>
    </div>
    <div class="sticky-atc__price" data-sticky-price>{{ product.selected_or_first_available_variant.price | money }}</div>
    <button type="button" class="btn btn-primary" data-sticky-add-btn {% unless product.available %}disabled{% endunless %}>{{ 'products.product.add_to_cart' | t }}</button>
  </div>
</div>

{% comment %} بيانات منظمة (Schema) للمنتج - تساعد جوجل يعرض السعر والتوفر مباشرة بنتائج البحث {% endcomment %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 300 | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
  "image": [{{ product.featured_image | image_url: width: 1200 | prepend: "https:" | json }}],
  "offers": {
    "@type": "AggregateOffer",
    "url": {{ request.origin | append: product.url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "lowPrice": {{ product.price_min | divided_by: 100.0 | json }},
    "highPrice": {{ product.price_max | divided_by: 100.0 | json }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
  }
  {% if section.settings.show_rating and section.settings.rating_count > 0 and section.settings.average_rating != blank %}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ section.settings.average_rating | json }},
    "reviewCount": {{ section.settings.rating_count | json }}
  }
  {% endif %}
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": {{ shop.name | json }}, "item": {{ request.origin | json }} },
    {% if product.collections.first %}
    { "@type": "ListItem", "position": 2, "name": {{ product.collections.first.title | json }}, "item": {{ request.origin | append: product.collections.first.url | json }} },
    { "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ request.origin | append: product.url | json }} }
    {% else %}
    { "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ request.origin | append: product.url | json }} }
    {% endif %}
  ]
}
</script>

{% assign faq_blocks = section.blocks | where: 'type', 'faq' %}
{% if faq_blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for block in faq_blocks %}
      {
        "@type": "Question",
        "name": {{ block.settings.question | json }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | json }} }
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>
{% endif %}

{% schema %}
{
  "name": "صفحة المنتج",
  "settings": [
    { "type": "checkbox", "id": "show_buy_now", "label": "إظهار زر (اشترِ الآن)", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "إظهار ملخص التقييم", "default": true },
    { "type": "range", "id": "rating_count", "label": "عدد التقييمات", "min": 0, "max": 500, "step": 5, "default": 0 },
    { "type": "text", "id": "average_rating", "label": "متوسط التقييم (مثال: 4.8)", "info": "اتركه فارغاً إذا لم تتوفر تقييمات حقيقية بعد — لا تضع رقم وهمي، جوجل يعاقب على البيانات المزيفة." },
    { "type": "text", "id": "delivery_estimate", "label": "نص وقت التوصيل" },
    { "type": "textarea", "id": "brew_instructions", "label": "طريقة التحضير" },
    { "type": "textarea", "id": "shipping_info", "label": "معلومات الشحن" }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "شارة ثقة",
      "settings": [
        { "type": "text", "id": "text", "label": "النص", "default": "دفع آمن 100٪" }
      ]
    },
    {
      "type": "faq",
      "name": "سؤال شائع",
      "settings": [
        { "type": "text", "id": "question", "label": "السؤال" },
        { "type": "textarea", "id": "answer", "label": "الجواب" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "trust_badge", "settings": { "text": "دفع آمن 100٪" } },
      { "type": "trust_badge", "settings": { "text": "شحن سريع" } },
      { "type": "trust_badge", "settings": { "text": "إرجاع خلال 7 أيام" } }
    ]
  }
}
{% endschema %}
